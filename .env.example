# ============================================================
# Variables de entorno requeridas para correr la aplicación
# ============================================================
# Copiar este archivo como .env y completar los valores reales.
# NUNCA subir el .env al repositorio.
#
# Cómo distribuir las claves al equipo:
#   - Compartir el .env por un canal seguro fuera del repo (ej: mensaje directo, vault, etc.)
#   - En CI/CD cargarlas como secrets del pipeline (GitHub Actions Secrets, etc.)
# ============================================================

# ── Autenticación JWT ───────────────────────────────────────
# La app autentica con JWT (login email/contraseña → Authorization: Bearer).
# JWT_SECRET firma los tokens; usar un valor largo y aleatorio en producción.
#   Python : python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=kYf4yAsvwoKhhA4rln4dc5Dpu7eWBxB8iSWixQpyQCCMdbydSSeA1nkMbX1B8HQF
# Contraseña de los usuarios demo sembrados (marcos@utn / jeronimo@utn).
SEED_USER_PASSWORD=figuswap123

# ── Base de Datos MongoDB ───────────────────────────────────
#
# Opción A — MongoDB local con Docker (docker compose up):
#   MONGODB_URL=mongodb://mongodb:27017
#   (usar "localhost" en vez de "mongodb" si se corre el backend fuera de Docker)
#
# Tests:
#   - Si querés forzar la URL usada por pytest, definí TEST_MONGODB_URL.
#   - Ejemplo fuera de Docker: TEST_MONGODB_URL=mongodb://localhost:27017
#
# Opción B — MongoDB Atlas (nube):
#   MONGODB_URL=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
#
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=mundial_figuritas_db

# Base de datos exclusiva para tests (se borra entera al terminar la suite).
# Si se omiten, pytest detecta el host (mongodb en Docker, localhost fuera) y usa
# la base mundial_figuritas_test — nunca la de dev/producción.
TEST_MONGODB_URL=mongodb://mongodb:27017
TEST_MONGODB_DB_NAME=mundial_figuritas_test

# ── CORS ────────────────────────────────────────────────────
# Orígenes permitidos para el frontend (formato JSON array).
# Dev local: dejar el valor por defecto.
# Producción: reemplazar con la URL real del frontend.
# CORS_ORIGINS=["http://localhost:5173"]

# ── Telegram Bot ────────────────────────────────────────────
# Token del bot de Telegram. Obtenerlo hablando con @BotFather en Telegram:
#   1. Abrir Telegram y buscar @BotFather
#   2. Enviar /newbot y seguir las instrucciones
#   3. Copiar el token que te da BotFather aquí
TELEGRAM_BOT_TOKEN=
