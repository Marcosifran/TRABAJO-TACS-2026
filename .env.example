# ============================================================
# Variables de entorno requeridas para correr la aplicación
# ============================================================
# Copiar este archivo como .env y completar los valores reales.
#
# Cómo generar un token seguro:
#   Python : python -c "import uuid; print(uuid.uuid4())"
#   Linux  : uuidgen
#
# Cómo disponibilizar las keys al equipo:
#   - Compartir el .env por un canal seguro fuera del repo (ej: mensaje directo, vault, etc.)
#   - Cada integrante crea su propio .env local con estos valores
#   - En CI/CD se cargan como secrets del pipeline (GitHub Actions Secrets, etc.)
# ============================================================

# ── Backend (leídas por pydantic-settings) ──────────────────
USER_1_TOKEN=
USER_2_TOKEN=

# ── Frontend (leídas por Vite — deben tener prefijo VITE_) ──
# Deben coincidir con los valores de arriba
VITE_USER_1_TOKEN=
VITE_USER_2_TOKEN=
